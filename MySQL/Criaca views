/*Criação da view vwfunc_dep */
create view vwfunc_dep as 
select f.nome, f.cargo as funcionario, 
d.nome as departamento from funcionario f inner join departamento d on f.departamento_id = d.id


/*forma de chamar a view*/
SELECT * FROM vwfunc_dep;

select * from vwfunc_dep where departamento = 'RH'